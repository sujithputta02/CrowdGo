# Firebase Configuration (Public - Safe to expose in client-side code)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# PubSub Verification Token (Keep secret)
PUBSUB_VERIFICATION_TOKEN=your-secret-token

# Google Maps API Key (Restrict in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Service Account (Use gcp-key.json file instead)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=your-base64-encoded-private-key

# Vertex AI Configuration
VERTEX_AI_ENDPOINT_ID=""
VERTEX_AI_LOCATION="us-central1"
